---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site.js";

const withBase = (path = "") => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${String(path).replace(/^\//, "")}`;
};
const cvPdf = withBase("assets/cv/Cristhian-Guerrero-Zaldivar-CV.pdf");
---

<BaseLayout title={`${site.name} | Resume`} description={`Print-ready resume for ${site.name}.`} page="resume/">
  <main class="resume-page">
    <section class="resume-shell">
      <div class="resume-topbar">
        <a href={withBase()}>← Back to main landing</a>
        <div class="resume-topbar-actions">
          <button type="button" onclick="window.print()">Print / Save as PDF</button>
          <a href={cvPdf} download>Download generated PDF</a>
        </div>
      </div>

      <header class="resume-hero">
        <div>
          <p>{site.role}</p>
          <h1>{site.name}</h1>
          <h2>Founder of FlowMind Studio · Austin, Texas</h2>
        </div>

        <div class="resume-contact">
          <a href={site.links.email}>{site.email}</a>
          <a href={site.links.sms}>{site.phoneDisplay}</a>
          <a href={site.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a href={site.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
          <a href={site.links.flowmind} target="_blank" rel="noreferrer noopener">FlowMind Studio</a>
        </div>
      </header>

      <section class="resume-section">
        <h3>Profile</h3>
        <p>
          Austin-based developer and founder leading FlowMind Studio. I build artistic websites,
          trustworthy digital systems, and clean public-facing experiences that connect clear communication,
          search visibility, and professional credibility.
        </p>
      </section>

      <section class="resume-section">
        <h3>Selected Work</h3>
        <div class="resume-list">
          {site.portfolio.map((project) => (
            <article>
              <strong>{project.title}</strong>
              <span>{project.category}</span>
              <p>{project.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="resume-section">
        <h3>Experience</h3>
        <div class="resume-list">
          {site.experience.map((item) => (
            <article>
              <div class="resume-row">
                <strong>{item.title} · {item.company}</strong>
                <span>{item.start} — {item.end}</span>
              </div>
              <span>{item.location}</span>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="resume-grid">
        <div class="resume-section">
          <h3>Strengths</h3>
          <ul>
            {site.strengths.map((item) => <li>{item.title}</li>)}
          </ul>
        </div>

        <div class="resume-section">
          <h3>Education</h3>
          <div class="resume-list">
            {site.education.map((item) => (
              <article>
                <strong>{item.school}</strong>
                <span>{item.start} — {item.end}</span>
                <p>{item.degree}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </section>
  </main>

  <style>
    .resume-page {
      width: min(100vw, 1180px);
      margin: 0 auto;
      padding: 2rem 1rem 4rem;
    }

    .resume-shell {
      padding: 1.5rem;
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(8, 16, 28, 0.9);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
    }

    .resume-topbar,
    .resume-row,
    .resume-hero,
    .resume-contact {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
    }

    .resume-topbar {
      align-items: center;
      margin-bottom: 2rem;
      color: var(--muted);
    }

    .resume-topbar-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .resume-topbar-actions a,
    .resume-topbar-actions button {
      padding: 0.75rem 1rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.04);
      color: inherit;
      cursor: pointer;
    }

    .resume-hero {
      align-items: flex-start;
      padding-bottom: 2rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .resume-hero p {
      color: var(--accent-cool);
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 0.78rem;
    }

    .resume-hero h1 {
      max-width: none;
      font-size: clamp(2.8rem, 6vw, 5rem);
    }

    .resume-hero h2 {
      margin-top: 0.75rem;
      font-size: clamp(1.1rem, 2vw, 1.8rem);
      color: var(--muted);
    }

    .resume-contact {
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
    }

    .resume-section {
      margin-bottom: 2rem;
    }

    .resume-section h3 {
      margin-bottom: 1rem;
      font-size: 1.4rem;
    }

    .resume-list {
      display: grid;
      gap: 1rem;
    }

    .resume-list article {
      padding: 1rem 1.1rem;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
    }

    .resume-list strong,
    .resume-list span {
      display: block;
    }

    .resume-list span {
      margin: 0.3rem 0 0.6rem;
      color: var(--muted-soft);
      font-size: 0.92rem;
    }

    .resume-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }

    .resume-section ul {
      margin: 0;
      padding-left: 1.15rem;
      color: var(--muted);
    }

    .resume-section li + li {
      margin-top: 0.45rem;
    }

    @media (max-width: 900px) {
      .resume-topbar,
      .resume-hero,
      .resume-row,
      .resume-grid {
        flex-direction: column;
        grid-template-columns: 1fr;
      }

      .resume-contact {
        align-items: flex-start;
        text-align: left;
      }
    }

    @media print {
      body {
        background: #fff !important;
        color: #111 !important;
      }

      .ambient,
      .noise {
        display: none !important;
      }

      .resume-page {
        width: 100%;
        padding: 0;
      }

      .resume-shell {
        background: #fff;
        color: #111;
        border: none;
        box-shadow: none;
      }

      .resume-topbar {
        display: none;
      }

      .resume-list article {
        background: transparent;
        border-color: rgba(17, 17, 17, 0.12);
      }

      .resume-hero h2,
      .resume-list span,
      .resume-section ul,
      .resume-list p {
        color: #333 !important;
      }
    }
  </style>
</BaseLayout>
