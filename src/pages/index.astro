---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site.js";

const withBase = (path = "") => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${String(path).replace(/^\//, "")}`;
};

const founderPortrait = withBase(site.assets.portrait);
const cvPdf = withBase("assets/cv/Cristhian-Guerrero-Zaldivar-CV.pdf");
---

<BaseLayout>
  <a class="skip-link" href="#main-content">Skip to content</a>

  <header class="site-header">
    <a class="brand" href="#top" aria-label="Back to top">
      <span class="brand-mark">
        <img src={withBase("favicon.svg")} alt="" width="42" height="42" />
      </span>
      <span class="brand-copy">
        <strong>{site.name}</strong>
        <small>{site.role}</small>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#about">About</a>
      <a href="#business">Business</a>
      <a href="#work">Work</a>
      <a href="#contact">Contact</a>
    </nav>

    <a class="nav-cta" href={site.links.flowmind} target="_blank" rel="noreferrer noopener">
      FlowMind Studio
    </a>
  </header>

  <main id="main-content">
    <section class="hero section" id="top">
      <div class="hero-copy">
        <p class="eyebrow">{site.hero.eyebrow}</p>
        <h1>{site.hero.title}</h1>
        <p class="hero-intro">{site.hero.intro}</p>
        <p class="hero-body">{site.hero.body}</p>

        <div class="hero-actions">
          <a
            class="button button-primary"
            href={site.links.flowmind}
            target="_blank"
            rel="noreferrer noopener"
          >
            {site.hero.ctas.primary}
          </a>
          <a class="button button-secondary" href="#work">{site.hero.ctas.secondary}</a>
          <a class="button button-ghost" href={site.links.email}>{site.hero.ctas.tertiary}</a>
        </div>

        <dl class="hero-facts">
          {site.facts.map((fact) => (
            <div>
              <dt>{fact.value}</dt>
              <dd>{fact.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <figure class="founder-visual">
        <img
          src={founderPortrait}
          alt={`Portrait of ${site.name}`}
          width="1122"
          height="1122"
          loading="eager"
        />
        <figcaption>
          <span>{site.basedIn}</span>
          <strong>Founder of FlowMind Studio, focused on clean business presence online.</strong>
        </figcaption>
      </figure>
    </section>

    <section class="section about-section" id="about">
      <div class="section-heading">
        <p class="section-kicker">{site.bio.kicker}</p>
        <h2>{site.bio.title}</h2>
      </div>

      <div class="about-copy">
        {site.bio.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        <div class="credential-strip" aria-label="Professional focus">
          <span>Founder-led</span>
          <span>Cybersecurity-aware</span>
          <span>Business-focused</span>
        </div>
      </div>
    </section>

    <section class="section business-section" id="business">
      <div class="business-copy">
        <p class="section-kicker">{site.business.kicker}</p>
        <h2>{site.business.title}</h2>
        <p>{site.business.body}</p>
      </div>

      <ul class="service-list" role="list">
        {site.services.map((service) => <li>{service}</li>)}
      </ul>
    </section>

    <section class="section work-section" id="work">
      <div class="section-heading section-heading-wide">
        <p class="section-kicker">Selected work</p>
        <h2>Real websites connected to real business outcomes.</h2>
        <p>
          A focused selection of projects that show how I connect design, development,
          search structure, and practical trust.
        </p>
      </div>

      <div class="project-grid">
        {site.portfolio.map((project) => (
          <article class="project-card">
            <a
              class="project-media"
              href={project.href}
              target="_blank"
              rel="noreferrer noopener"
              aria-label={`Visit ${project.title}`}
            >
              {project.image ? (
                <img
                  src={withBase(project.image)}
                  alt={`${project.title} website preview`}
                  loading="lazy"
                  width="1120"
                  height="700"
                />
              ) : (
                <div class="project-brand-tile">
                  <span>FlowMind Studio</span>
                  <strong>Founder website</strong>
                </div>
              )}
            </a>

            <div class="project-body">
              <div>
                <p class="project-meta">{project.category}</p>
                <h3>{project.title}</h3>
              </div>
              <p>{project.summary}</p>
              <ul class="tag-list" role="list">
                {project.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <a
                class="text-link"
                href={project.href}
                target="_blank"
                rel="noreferrer noopener"
              >
                {project.hrefLabel}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section contact-section" id="contact">
      <div class="contact-copy">
        <p class="section-kicker">Contact</p>
        <h2>For business, collaboration, or professional opportunities, reach out directly.</h2>
        <p>
          This page is meant to connect my name, my work, and my business presence in one clean place.
        </p>

        <div class="contact-methods">
          {site.contactMethods.map((method) => (
            <a
              class="contact-card"
              href={method.href}
              target={method.href.startsWith("http") ? "_blank" : undefined}
              rel="noreferrer noopener"
            >
              <span>{method.label}</span>
              <strong>{method.value}</strong>
              <p>{method.note}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="resume-card">
        <p class="section-kicker">Resume</p>
        <h3>Need the structured version?</h3>
        <p>A focused technical resume is available for formal hiring workflows.</p>
        <div class="resume-actions">
          <a class="button button-primary" href={withBase("resume/")}>Open resume</a>
          <a class="button button-secondary" href={cvPdf} download>Download PDF</a>
        </div>
      </aside>
    </section>
  </main>

  <footer class="site-footer">
    <p>{site.footerNote}</p>
  </footer>
</BaseLayout>
