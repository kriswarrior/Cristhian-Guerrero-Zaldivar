---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site.js";

const withBase = (path = "") => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${String(path).replace(/^\//, "")}`;
};
const portrait = withBase("assets/profile/cristhian-guerrero-zaldivar-portrait.png");
const cvPdf = withBase("assets/cv/Cristhian-Guerrero-Zaldivar-CV.pdf");
---

<BaseLayout>
  <a class="skip-link" href="#main-content">Skip to content</a>

  <header class="site-header">
    <a class="brand" href="#top" aria-label="Back to top">
      <span class="brand-mark">CG</span>
      <span class="brand-copy">
        <strong>{site.name}</strong>
        <small>{site.role}</small>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="#story">Approach</a>
      <a href="#portfolio">Work</a>
      <a href="#experience">Experience</a>
      <a href="#capabilities">Range</a>
      <a href="#contact">Contact</a>
    </nav>

    <a class="nav-cta" href={site.links.flowmind} target="_blank" rel="noreferrer noopener">
      FlowMind Studio
    </a>
  </header>

  <main id="main-content">
    <section class="hero-scene section-screen" id="top">
      <div class="section-grid" aria-hidden="true"></div>
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">{site.hero.eyebrow}</p>
        <h1>{site.hero.title}</h1>
        <p class="hero-intro">{site.hero.intro}</p>
        <p class="hero-body">{site.hero.body}</p>

        <div class="hero-actions">
          <a class="button button-primary" href={site.links.email}>{site.hero.ctas.primary}</a>
          <a class="button button-secondary" href={withBase("resume/")}>{site.hero.ctas.secondary}</a>
          <a
            class="button button-ghost"
            href={site.links.flowmind}
            target="_blank"
            rel="noreferrer noopener"
          >
            {site.hero.ctas.tertiary}
          </a>
        </div>

        <ul class="signal-row" role="list">
          <li>Based in Austin, Texas</li>
          <li>Founder-led</li>
          <li>English-first presence</li>
          <li>Built for real search</li>
        </ul>
      </div>

      <div class="hero-stage" data-reveal>
        <div class="portrait-shell">
          <div class="portrait-cut">
            <img src={portrait} alt={`Studio portrait of ${site.name}`} width="1254" height="1254" />
          </div>
        </div>

        <div class="floating-card floating-card-a">
          <span>FlowMind Studio</span>
          <strong>Founder-led, team of four</strong>
        </div>
        <div class="floating-card floating-card-b">
          <span>Public signal</span>
          <strong>Designed to feel clear, human, and credible</strong>
        </div>
        <div class="floating-card floating-card-c">
          <span>Search identity</span>
          <strong>{site.name} · Austin, Texas · Developer</strong>
        </div>
      </div>

      <div class="hero-pullquote" data-reveal>
        <p>{site.hero.pullquote}</p>
      </div>

      <div class="signal-grid" data-reveal>
        {site.signals.map((signal) => (
          <article class="signal-card">
            <span>{signal.value}</span>
            <p>{signal.label}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="story-scene section-screen" id="story">
      <div class="story-copy" data-reveal>
        <p class="section-kicker">Approach</p>
        <h2>Close enough to feel human. Structured enough to hold up professionally.</h2>
        <p>
          I want my online presence to feel like a real introduction, not a brochure. That means clear
          communication, controlled motion, strong typography, and engineering choices that make the site
          fast, indexable, and trustworthy.
        </p>
      </div>

      <div class="manifesto-grid">
        {site.manifesto.map((item, index) => (
          <article class="manifesto-card" data-reveal style={`--card-index:${index};`}>
            <span class="manifesto-index">0{index + 1}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="portfolio-scene section-screen" id="portfolio">
      <div class="section-head" data-reveal>
        <p class="section-kicker">Selected Work</p>
        <h2>Real websites in the wild, not just polished mockups.</h2>
        <p>
          These are the live projects I most want connected to my name and to FlowMind Studio. The goal
          is simple: real businesses, strong presence, and better trust online.
        </p>
      </div>

      <div class="portfolio-shell" data-portfolio-shell data-reveal>
        <button class="portfolio-arrow" type="button" data-portfolio-prev aria-label="Previous project">
          <span aria-hidden="true">‹</span>
        </button>

        <div class="portfolio-track" role="region" aria-label="Selected projects carousel">
          {site.portfolio.map((project, index) => (
            <article class="portfolio-card" data-portfolio-card data-index={index}>
              <div class={`portfolio-media ${project.image ? "" : "portfolio-media-brand"}`}>
                {project.image ? (
                  <img
                    src={withBase(project.image)}
                    alt={`${project.title} project preview`}
                    loading="lazy"
                    width="1120"
                    height="700"
                  />
                ) : (
                  <div class="brand-poster">
                    <span>FlowMind Studio</span>
                    <strong>Founder website</strong>
                    <p>Art direction, local SEO, conversion logic, and clean digital trust.</p>
                  </div>
                )}
                <span class="portfolio-badge">{project.metric}</span>
              </div>

              <div class="portfolio-body">
                <div class="portfolio-heading">
                  <div>
                    <p class="portfolio-category">{project.category}</p>
                    <h3>{project.title}</h3>
                  </div>
                  <span class="portfolio-location">{project.location}</span>
                </div>

                <p class="portfolio-summary">{project.summary}</p>
                <p class="portfolio-detail">{project.detail}</p>

                <ul class="portfolio-tags" role="list">
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>

                <div class="portfolio-actions">
                  <a
                    class="button button-primary"
                    href={project.href}
                    target="_blank"
                    rel="noreferrer noopener"
                  >
                    {project.hrefLabel}
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <button class="portfolio-arrow" type="button" data-portfolio-next aria-label="Next project">
          <span aria-hidden="true">›</span>
        </button>
      </div>

      <div class="concept-lab" data-reveal>
        <div class="concept-copy">
          <p class="section-kicker">Concept Lab</p>
          <h3>Extra visual directions from my sketchbook.</h3>
          <p>
            I also explore other industries and moods to keep the work sharp. These concepts are not the
            main proof. They show taste, range, and visual discipline.
          </p>
        </div>

        <div class="concept-grid">
          {site.conceptLab.map((project) => (
            <article class="concept-card">
              <img src={withBase(project.image)} alt={project.title} loading="lazy" width="1120" height="700" />
              <div>
                <h4>{project.title}</h4>
                <p>{project.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="experience-scene section-screen" id="experience">
      <div class="section-head section-head-narrow" data-reveal>
        <p class="section-kicker">Experience</p>
        <h2>A practical career arc shaped by pressure, responsibility, and execution.</h2>
        <p>
          My background is not theoretical. It moves through cybersecurity, operations, team leadership,
          and founder work. That mix changed how I build: calm, clear, accountable, and hard to rattle.
        </p>
      </div>

      <div class="timeline">
        {site.experience.map((item, index) => (
          <article class="timeline-card" data-reveal style={`--timeline-index:${index};`}>
            <span class="timeline-range">{item.start} — {item.end}</span>
            <h3>{item.title}</h3>
            <p class="timeline-company">{item.company}</p>
            <p class="timeline-location">{item.location}</p>
            <p class="timeline-body">{item.body}</p>
            <ul class="timeline-highlights" role="list">
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <div class="education-panel" data-reveal>
        <p class="section-kicker">Education</p>
        <div class="education-grid">
          {site.education.map((item) => (
            <article class="education-card">
              <h3>{item.school}</h3>
              <p>{item.degree}</p>
              <span>{item.start} — {item.end}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="capabilities-scene section-screen" id="capabilities">
      <div class="section-head" data-reveal>
        <p class="section-kicker">Range</p>
        <h2>I can lead product direction, software direction, and the engineering conversation.</h2>
        <p>
          The surface of my work is visual and clear. Underneath that, there is systems thinking,
          architecture awareness, security discipline, and a lot of respect for execution quality.
        </p>
      </div>

      <div class="strength-grid">
        {site.strengths.map((item, index) => (
          <article class="strength-card" data-reveal style={`--strength-index:${index};`}>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>

      <div class="engineering-grid" data-reveal>
        {site.engineeringRange.map((group) => (
          <article class="engineering-card">
            <h3>{group.title}</h3>
            <ul class="chip-list" role="list">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="contact-scene section-screen" id="contact">
      <div class="contact-copy" data-reveal>
        <p class="section-kicker">Contact</p>
        <h2>If you found this page by name, by business, or by curiosity, you found the right person.</h2>
        <p>
          I want the internet version of me to feel the same way I work in real life: approachable,
          grounded, detail-aware, and professionally solid. If that matches what you need, reach out
          directly.
        </p>

        <div class="contact-methods">
          {site.contactMethods.map((method) => (
            <a class="contact-card" href={method.href} target={method.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer noopener">
              <span>{method.label}</span>
              <strong>{method.value}</strong>
              <p>{method.note}</p>
            </a>
          ))}
        </div>

        <div class="social-strip">
          <a href={site.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a href={site.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
          <a href={site.links.flowmind} target="_blank" rel="noreferrer noopener">FlowMind Studio</a>
        </div>
      </div>

      <aside class="resume-panel" data-reveal>
        <p class="section-kicker">Resume</p>
        <h3>Need the structured version?</h3>
        <p>
          I also built a print-ready resume route and a downloadable PDF snapshot so this site works for
          both search presence and formal hiring workflows.
        </p>

        <div class="resume-actions">
          <a class="button button-primary" href={withBase("resume/")}>Open resume page</a>
          <a class="button button-secondary" href={cvPdf} download>Download PDF CV</a>
        </div>

        <div class="resume-meta">
          <span>Main name: {site.name}</span>
          <span>Role: {site.role}</span>
          <span>Business: FlowMind Studio</span>
        </div>
      </aside>
    </section>
  </main>

  <footer class="site-footer">
    <p>{site.footerNote}</p>
  </footer>

  <script is:inline>
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const root = document.documentElement;
    const revealTargets = document.querySelectorAll("[data-reveal]");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      },
      { threshold: 0.18 }
    );

    revealTargets.forEach((target) => observer.observe(target));

    if (!reduceMotion) {
      const onPointerMove = (event) => {
        const x = event.clientX / window.innerWidth;
        const y = event.clientY / window.innerHeight;
        root.style.setProperty("--pointer-x", x.toFixed(4));
        root.style.setProperty("--pointer-y", y.toFixed(4));
      };

      const onScroll = () => {
        const progress = window.scrollY / Math.max(document.body.scrollHeight - window.innerHeight, 1);
        root.style.setProperty("--scroll-progress", progress.toFixed(4));
      };

      window.addEventListener("pointermove", onPointerMove);
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }

    const portfolioShell = document.querySelector("[data-portfolio-shell]");

    if (portfolioShell) {
      const cards = Array.from(portfolioShell.querySelectorAll("[data-portfolio-card]"));
      const prevButton = portfolioShell.querySelector("[data-portfolio-prev]");
      const nextButton = portfolioShell.querySelector("[data-portfolio-next]");
      let activeIndex = 0;

      const renderCarousel = () => {
        cards.forEach((card, index) => {
          const distance = (index - activeIndex + cards.length) % cards.length;
          const reverseDistance = (activeIndex - index + cards.length) % cards.length;
          let state = "hidden";

          if (index === activeIndex) state = "active";
          else if (distance === 1) state = "next";
          else if (reverseDistance === 1) state = "prev";

          card.dataset.state = state;
          card.setAttribute("aria-hidden", state === "hidden" ? "true" : "false");
        });
      };

      prevButton?.addEventListener("click", () => {
        activeIndex = (activeIndex - 1 + cards.length) % cards.length;
        renderCarousel();
      });

      nextButton?.addEventListener("click", () => {
        activeIndex = (activeIndex + 1) % cards.length;
        renderCarousel();
      });

      renderCarousel();
    }
  </script>
</BaseLayout>
